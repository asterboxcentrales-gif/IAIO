{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ai-shell",
  "version": "0.1.0",
  "identifier": "os.ai.shell",

  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../src"
  },

  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AI-OS",
        "width": 1920,
        "height": 1080,
        "fullscreen": true,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "transparent": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
